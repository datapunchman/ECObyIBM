		lineageTag: 77fbebfe-341f-49aa-b0b6-c0a3b367c98f
		summarizeBy: none
		sourceColumn: UnitsSold

		annotation SummarizationSetBy = Automatic

		annotation Description = "Total units of this product sold across all time periods. Pre-aggregated."

	column AvgSellingPrice
		dataType: double
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: Product Performance
		lineageTag: 7acd94a5-c28f-454d-b154-488a3208becd
		summarizeBy: none
		sourceColumn: AvgSellingPrice

		annotation SummarizationSetBy = Automatic

		annotation Description = "Average selling price per unit for this product (TotalRevenue divided by UnitsSold)."

	column RevenueRank
