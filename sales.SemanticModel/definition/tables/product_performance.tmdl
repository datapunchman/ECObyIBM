	column ProductProfitMargin
		dataType: double
		formatString: 0.00%;-0.00%;0.00%
		displayFolder: Product Performance
		lineageTag: b433647b-c0ce-42b0-9e81-7a46a3215e95
		summarizeBy: none
		sourceColumn: ProductProfitMargin

		annotation SummarizationSetBy = Automatic

		annotation Description = "Gross profit margin % for this product. Pre-calculated; use the [Product Profit Margin %] measure for dynamic analysis."

	column UnitsSold
		dataType: int64
		formatString: #,0
