	column TotalRevenue
		dataType: double
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: Product Performance
		lineageTag: d2166aff-e854-48b3-ab40-8a8689e46454
		summarizeBy: none
		sourceColumn: TotalRevenue

		annotation SummarizationSetBy = Automatic

		annotation Description = "Total revenue generated by this product across all time periods. Pre-aggregated; use measures for filtered analysis."

	column TotalProfit
		dataType: double
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: Product Performance
		lineageTag: 88bf003b-b587-4bd2-97c2-d32ce32b8205
		summarizeBy: none
		sourceColumn: TotalProfit

		annotation SummarizationSetBy = Automatic

