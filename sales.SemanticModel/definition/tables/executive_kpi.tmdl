		displayFolder: Rankings
		lineageTag: 7ae469da-2799-4cd0-8db0-f93c137ab30c
		summarizeBy: none
		sourceColumn: HighestRevenueProduct

		annotation SummarizationSetBy = Automatic

		annotation Description = "Name of the product that generated the highest total revenue in the reporting period."

